rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's unique ID.
    //   - photoUrl: string (optional) - Base64 or URL of the user's photo for try-on.
    //   - displayName: string (optional) - User's display name.
    //   - email: string (optional) - User's email address.
    //
    // Collection: /users/{userId}/clothes/{clothingId}
    // Document ID: {clothingId}
    // Fields:
    //   - id: string (required) - Unique ID of the item.
    //   - uid: string (required) - Owner's unique ID.
    //   - name: string (required) - Name of the clothing item.
    //   - category: string (required, top|bottom|shoes|accessory|full-body) - Category of the item.
    //   - imageUrl: string (required) - Base64 or URL of the clothing image.
    //   - tags: list (optional) - Tags for the item.
    //   - createdAt: timestamp (optional) - Creation timestamp.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "avivgold08@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() < 1048576)) && // Max 1MB
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 255)) &&
             (!('role' in data) || (data.role in ['admin', 'user']));
    }

    function isValidClothing(data) {
      return data.keys().hasAll(['id', 'uid', 'name', 'category', 'imageUrl']) &&
             data.id is string &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in ['top', 'bottom', 'shoes', 'accessory', 'full-body', 'hoodie'] &&
             data.imageUrl is string && data.imageUrl.size() < 1048576 && // Max 1MB
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || isAdmin();
      allow delete: if isAdmin();

      match /clothes/{clothingId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidClothing(request.resource.data) && request.resource.data.uid == request.auth.uid;
        allow update: if (isOwner(userId) && isValidClothing(request.resource.data) && request.resource.data.uid == resource.data.uid) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
